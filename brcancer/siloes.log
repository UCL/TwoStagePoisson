. cap frame drop results

. frame create results siloes rep b se

. foreach siloes in 2 5 10 25 {
  2.         frame post results (`siloes') (0) ($b) ($se)
  3.         forvalues rep=1/`reps' {
  4.                 if `rep'==1 _dots 0, title("Simulation running (`reps' repetitions)")
  5.                 _dots `rep' 0
  6.                 cap drop random silo
  7.                 gen random = runiform()
  8.                 sort random
  9.                 gen silo = int(`siloes'*(_n-1)/_N)+1
 10.                 qui ipdmetan, study(silo) nograph: stcox hormon
 11.                 frame post results (`siloes') (`rep') (r(eff)) (r(se_eff))
 12.                 if `siloes'==25 & `rep'==11 qui save siloes`siloes'_`rep', replace
 13.                 * a fairly typical data set
.         }
 14.         frame results: label def siloes `siloes' "`siloes' siloes", modify      
 15. }
